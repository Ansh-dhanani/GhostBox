{
  "name": "@ghostbox/ttyd",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "node scripts/start.mjs",
    "dev:win": "ttyd -W -i 127.0.0.1 -p 7681 powershell.exe -NoLogo",
    "dev:wsl": "ttyd -W -i 127.0.0.1 -p 7681 wsl.exe",
    "dev:linux": "ttyd -W -i 127.0.0.1 -p 7681 tmux new -A -s terminal",
    "dev:mac": "ttyd -W -i 127.0.0.1 -p 7681 bash -l"
  }
}
