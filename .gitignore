# Terraform state contains secrets.
.terraform/
.terraform.lock.hcl
terraform.tfstate
terraform.tfstate.backup
**/.terraform/
**/.terraform.lock.hcl
**/terraform.tfstate
**/terraform.tfstate.backup

# Local secrets.
terraform.tfvars
**/terraform.tfvars

# Node / Next.js.
node_modules/
**/node_modules/
.next/
**/.next/
out/
**/out/
dist/
**/dist/
*.tsbuildinfo

# Downloaded portable binaries (regenerated by setup flow).
.bin/
!.bin/*.cmd
!.bin/*.ps1
!.bin/*.md
!.gitignore

# OS.
.DS_Store

# Environment files.
.env
**/.env

# Logs.
*.log
**/*.log

# Runtime generated config files
chocolate-doom.cfg
default.cfg
*.cfg

# OS metadata
Thumbs.db
Desktop.ini
